{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:bun.sh)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:files.pythonhosted.org)",
      "Bash(rm -rf node_modules package-lock.json)",
      "Bash(npm install *)",
      "Bash(UV_NO_CACHE=1 TMPDIR=/tmp uv pip install --system google-generativeai pydantic pydantic-settings mss pyautogui chromadb)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  }
}
