{
  "name": "jarvis-desktop",
  "version": "2.0.0",
  "main": "main.js",
  "description": "JARVIS Desktop Assistant - Fast AI Assistant",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "backend": "cd .. && python -m backend.main",
    "start": "concurrently -k \"npm run dev\" \"npm run backend\" \"wait-on http://localhost:5173 http://127.0.0.1:8000/health && electron .\"",
    "dev:full": "concurrently -k \"npm run backend\" \"npm run dev\" \"wait-on http://localhost:5173 http://127.0.0.1:8000/health && electron .\"",
    "build": "vite build",
    "build:app": "vite build && electron-builder --win portable",
    "dist": "npm run build:app"
  },
  "build": {
    "appId": "ai.jarvis.mark-xxxix",
    "productName": "JARVIS Desktop Assistant",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.4.2",
    "electron-is-dev": "^2.0.0",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "react-webcam": "^7.2.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "vite": "^6.0.3",
    "wait-on": "^7.2.0"
  },
  "author": "Rohan",
  "license": "MIT"
}